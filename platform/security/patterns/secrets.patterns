# HexOS Security — Hardcoded Secrets Pattern Database
# Category: secrets
# Risk Level: high
# Format: RISK_LEVEL|PATTERN_NAME|REGEX

high|aws_access_key|AKIA[0-9A-Z]{16}
high|aws_secret_key|(?i)(aws_secret_access_key|aws_secret)\s*[=:]\s*[A-Za-z0-9/+=]{40}
high|github_token|(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{36,}
high|openai_api_key|sk-proj-[A-Za-z0-9]{20,}
high|openai_api_key_legacy|sk-[A-Za-z0-9]{48}
high|generic_api_key|(?i)(api[_-]?key|apikey)\s*[=:]\s*['"][A-Za-z0-9_\-]{20,}['"]
high|generic_secret|(?i)(secret|password|passwd|pwd)\s*[=:]\s*['"][^'"]{8,}['"]
high|private_key_header|-----BEGIN\s+(RSA\s+)?PRIVATE\s+KEY-----
high|slack_token|xox[bpras]-[0-9A-Za-z\-]{10,}
high|stripe_key|sk_live_[0-9a-zA-Z]{24,}
high|telegram_bot_token|[0-9]+:AA[A-Za-z0-9_\-]{33}
high|jwt_token|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}
high|anthropic_key|sk-ant-[A-Za-z0-9_\-]{20,}
