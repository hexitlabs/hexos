#!/bin/bash
# HexOS CLI — Management interface for HexOS platform
# Phase 1: Workspace Jail management
# Phase 1.5: Security scanning
# Phase 2: Network Egress Control
# Phase 6: Audit Trail + Credential Sanitization
set -euo pipefail

PLATFORM_BIN="/hexos/platform/bin"
PLATFORM_SECURITY="/hexos/platform/security"
PLATFORM_NETWORK="/hexos/platform/network"
PLATFORM_AUDIT="/hexos/platform/audit"
VERSION="0.5.0"

show_help() {
    echo "HexOS CLI v${VERSION}"
    echo ""
    echo "Usage: hexos <command> <subcommand> [args]"
    echo ""
    echo "Commands:"
    echo "  client create <name>                Create a new client workspace jail"
    echo "  client remove <name> [--confirm]    Remove a client workspace jail"
    echo "  client status <name>                Show client status and stats"
    echo "  client list                         List all clients"
    echo ""
    echo "  egress apply <client> [--dry-run|--check-only]"
    echo "                                      Apply egress policy from YAML"
    echo "  egress remove <client>              Remove all egress rules"
    echo "  egress status <client>              Show rules + violation stats"
    echo "  egress test <client> <host> [port]  Test connectivity"
    echo "  egress reload <client>              Hot-reload rules"
    echo "  egress lockdown <client>            Emergency: block ALL egress"
    echo "  egress unlock <client>              Restore normal policy after lockdown"
    echo "  egress allow <client> <host[:port]> Quick-add endpoint to allowlist"
    echo "  egress presets                      List available egress presets"
    echo "  egress dns verify <client>          Verify DNS control is active"
    echo "  egress dns test <client>            Test DNS resolution"
    echo ""
    echo "  security verify <name>              Run security verification checks"
    echo "  security scan <type> <target> [policy]  Run security scan"
    echo "    scan skill <dir>                  Scan a skill directory"
    echo "    scan exec <command>               Scan a command before execution"
    echo "    scan workspace <dir> <client>     Scan a workspace directory"
    echo "    scan file <path>                  Scan a single file"
    echo "  security policy validate <file>     Validate a policy file"
    echo "  security policy resolve <client>    Show resolved policy for a client"
    echo "  security policy get <client> <key>  Get a policy value"
    echo "  security report [client]            Show recent scan reports"
    echo ""
    echo "  audit log <client> [options]         View audit log entries"
    echo "  audit search <client> <query>       Search audit entries"
    echo "  audit stats <client> [--period P]   Usage statistics"
    echo "  audit export <client> [options]     Export CSV/JSON"
    echo "  audit cleanup [--dry-run]           Retention cleanup"
    echo "  audit approve <request-id>          Approve pending request"
    echo "  audit reject <request-id>           Reject pending request"
    echo "  audit pending [client]              List pending approvals"
    echo "  audit verify <client> [date]        Verify hash chain integrity"
    echo "  audit alerts <client>               Run alert checks"
    echo ""
    echo "  setup [operator|managed]             Configure deployment profile"
    echo "  mode                                Show current profile + security status"
    echo "  deploy <client> [--presets p1,p2]   Full client deploy (managed mode only)"
    echo ""
    echo "  version                             Show version"
    echo "  help                                Show this help"
}

case "${1:-help}" in
    client)
        case "${2:-}" in
            create)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_BIN}/hexos-client-create.sh" "$3"
                ;;
            remove)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_BIN}/hexos-client-remove.sh" "${@:3}"
                ;;
            status)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_BIN}/hexos-client-stats.sh" "$3"
                ;;
            list)
                "${PLATFORM_BIN}/hexos-client-stats.sh" --all
                ;;
            *)
                echo "Usage: hexos client {create|remove|status|list}"
                exit 1
                ;;
        esac
        ;;
    security)
        case "${2:-}" in
            verify)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_BIN}/hexos-security-verify.sh" "$3"
                ;;
            scan)
                SCAN_TYPE="${3:-}"
                case "$SCAN_TYPE" in
                    skill)
                        [[ -z "${4:-}" ]] && echo "Error: skill directory required" && exit 1
                        "${PLATFORM_SECURITY}/scan-skill.sh" "$4" "${5:-}"
                        ;;
                    exec)
                        [[ -z "${4:-}" ]] && echo "Error: command required" && exit 1
                        "${PLATFORM_SECURITY}/scan-exec.sh" "$4" "${5:-}"
                        ;;
                    workspace)
                        [[ -z "${4:-}" || -z "${5:-}" ]] && echo "Error: workspace path and client-id required" && exit 1
                        "${PLATFORM_SECURITY}/scan-workspace.sh" "$4" "$5" "${6:-}"
                        ;;
                    file)
                        [[ -z "${4:-}" ]] && echo "Error: file path required" && exit 1
                        "${PLATFORM_SECURITY}/scanner.sh" "file" "$4" "${5:-}"
                        ;;
                    *)
                        echo "Usage: hexos security scan {skill|exec|workspace|file} <target> [policy]"
                        exit 1
                        ;;
                esac
                ;;
            policy)
                POLICY_ACTION="${3:-}"
                case "$POLICY_ACTION" in
                    validate)
                        [[ -z "${4:-}" ]] && echo "Error: policy file required" && exit 1
                        "${PLATFORM_SECURITY}/policy-loader.sh" validate "$4"
                        ;;
                    resolve)
                        [[ -z "${4:-}" ]] && echo "Error: client-id required" && exit 1
                        "${PLATFORM_SECURITY}/policy-loader.sh" resolve "$4"
                        ;;
                    get)
                        [[ -z "${4:-}" || -z "${5:-}" ]] && echo "Error: client-id and key required" && exit 1
                        "${PLATFORM_SECURITY}/policy-loader.sh" get "$4" "$5"
                        ;;
                    *)
                        echo "Usage: hexos security policy {validate|resolve|get} <args>"
                        exit 1
                        ;;
                esac
                ;;
            report)
                REPORTS_DIR="${REPORTS_DIR:-/tmp/hexos-security-reports}"
                CLIENT_FILTER="${3:-}"
                echo "╔══════════════════════════════════════════════════╗"
                echo "║  HexOS Security Reports                          ║"
                echo "╚══════════════════════════════════════════════════╝"
                echo ""
                if [[ ! -d "$REPORTS_DIR" ]]; then
                    echo "No reports found."
                    exit 0
                fi
                if [[ -n "$CLIENT_FILTER" ]]; then
                    ls -lt "$REPORTS_DIR"/*"${CLIENT_FILTER}"* 2>/dev/null | head -20 || echo "No reports for client: $CLIENT_FILTER"
                else
                    ls -lt "$REPORTS_DIR"/*.json 2>/dev/null | head -20 || echo "No reports found."
                fi
                ;;
            *)
                echo "Usage: hexos security {verify|scan|policy|report}"
                exit 1
                ;;
        esac
        ;;
    egress)
        case "${2:-}" in
            apply)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-apply.sh" "${@:3}"
                ;;
            remove)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-remove.sh" "$3"
                ;;
            status)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-status.sh" "$3"
                ;;
            test)
                [[ -z "${3:-}" || -z "${4:-}" ]] && echo "Error: client name and host required" && exit 1
                "${PLATFORM_NETWORK}/egress-test.sh" "$3" "$4" "${5:-443}"
                ;;
            reload)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-reload.sh" "$3"
                ;;
            lockdown)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-lockdown.sh" "$3"
                ;;
            unlock)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_NETWORK}/egress-unlock.sh" "$3"
                ;;
            allow)
                [[ -z "${3:-}" || -z "${4:-}" ]] && echo "Error: client name and host[:port] required" && exit 1
                "${PLATFORM_NETWORK}/egress-allow.sh" "$3" "$4"
                ;;
            presets)
                echo "Available egress presets:"
                echo ""
                PRESETS_DIR="/hexos/platform/config/egress-presets"
                if [[ -d "$PRESETS_DIR" ]]; then
                    for f in "${PRESETS_DIR}"/*.yaml; do
                        [[ -f "$f" ]] || continue
                        name=$(basename "$f" .yaml)
                        desc=$(yq -r '.description // "No description"' "$f" 2>/dev/null || echo "No description")
                        hosts=$(yq -r '.allow[]?.host // empty' "$f" 2>/dev/null | tr '\n' ', ' | sed 's/,$//')
                        printf "  %-16s %s\n" "$name" "$desc"
                        [[ -n "$hosts" ]] && printf "  %-16s Hosts: %s\n" "" "$hosts"
                    done
                else
                    echo "  No presets directory found"
                fi
                ;;
            dns)
                DNS_ACTION="${3:-}"
                case "$DNS_ACTION" in
                    verify)
                        [[ -z "${4:-}" ]] && echo "Error: client name required" && exit 1
                        "${PLATFORM_NETWORK}/dns-control.sh" verify "$4"
                        ;;
                    show)
                        [[ -z "${4:-}" ]] && echo "Error: client name required" && exit 1
                        "${PLATFORM_NETWORK}/dns-control.sh" show "$4"
                        ;;
                    test)
                        [[ -z "${4:-}" ]] && echo "Error: client name required" && exit 1
                        "${PLATFORM_NETWORK}/dns-control.sh" test "$4"
                        ;;
                    *)
                        echo "Usage: hexos egress dns {verify|show|test} <client>"
                        exit 1
                        ;;
                esac
                ;;
            *)
                echo "Usage: hexos egress {apply|remove|status|test|reload|lockdown|unlock|allow|presets|dns}"
                exit 1
                ;;
        esac
        ;;
    audit)
        case "${2:-}" in
            log)
                shift 2
                "${PLATFORM_AUDIT}/viewer.sh" log "$@"
                ;;
            search)
                shift 2
                "${PLATFORM_AUDIT}/viewer.sh" search "$@"
                ;;
            stats)
                shift 2
                "${PLATFORM_AUDIT}/viewer.sh" stats "$@"
                ;;
            export)
                shift 2
                "${PLATFORM_AUDIT}/export.sh" "$@"
                ;;
            cleanup)
                "${PLATFORM_AUDIT}/alerts.sh" cleanup "${3:-}"
                ;;
            approve)
                [[ -z "${3:-}" ]] && echo "Error: request ID required" && exit 1
                "${PLATFORM_AUDIT}/approve.sh" approve "$3" "${4:-}"
                ;;
            reject)
                [[ -z "${3:-}" ]] && echo "Error: request ID required" && exit 1
                "${PLATFORM_AUDIT}/approve.sh" reject "$3" "${4:-}"
                ;;
            pending)
                "${PLATFORM_AUDIT}/approve.sh" pending "${3:-}"
                ;;
            verify)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                source "${PLATFORM_AUDIT}/logger.sh"
                audit_verify_chain "$3" "${4:-}"
                ;;
            alerts)
                [[ -z "${3:-}" ]] && echo "Error: client name required" && exit 1
                "${PLATFORM_AUDIT}/alerts.sh" check "$3"
                ;;
            *)
                echo "Usage: hexos audit {log|search|stats|export|cleanup|approve|reject|pending|verify|alerts}"
                exit 1
                ;;
        esac
        ;;
    setup)
        "${PLATFORM_BIN}/hexos-setup.sh" "${2:-}"
        ;;
    mode)
        "${PLATFORM_BIN}/hexos-mode.sh"
        ;;
    deploy)
        shift
        "${PLATFORM_BIN}/hexos-deploy-client.sh" "$@"
        ;;
    version)
        echo "HexOS CLI v${VERSION}"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
